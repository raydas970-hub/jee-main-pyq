{\n  "year": 2016,\n  "month": "April",\n  "session": "JEE Main 2016",\n  "questions": [\n    {\n      "id": "2016_04_001",\n      "question_text": "A body is thrown vertically upward with velocity u. The greatest height h to which it rises is:",\n      "subject": "Physics",\n      "difficulty": "Easy",\n      "options": [\n        {\n          "option": "A",\n          "value": "u²/2g",\n          "is_correct": true\n        },\n        {\n          "option": "B",\n          "value": "u²/g",\n          "is_correct": false\n        },\n        {\n          "option": "C",\n          "value": "2u²/g",\n          "is_correct": false\n        },\n        {\n          "option": "D",\n          "value": "u/2g",\n          "is_correct": false\n        }\n      ],\n      "correct_answer": "A",\n      "explanation": "Using v² = u² - 2gh, at maximum height v = 0, so h = u²/2g",\n      "marks": 4\n    },\n    {\n      "id": "2016_04_002",\n      "question_text": "The oxidation state of nitrogen in NO₂ is:",\n      "subject": "Chemistry",\n      "difficulty": "Easy",\n      "options": [\n        {\n          "option": "A",\n          "value": "+2",\n          "is_correct": false\n        },\n        {\n          "option": "B",\n          "value": "+4",\n          "is_correct": true\n        },\n        {\n          "option": "C",\n          "value": "+3",\n          "is_correct": false\n        },\n        {\n          "option": "D",\n          "value": "+5",\n          "is_correct": false\n        }\n      ],\n      "correct_answer": "B",\n      "explanation": "In NO₂, nitrogen has an oxidation state of +4. Using the rule that oxygen is -2, we get: N + 2(-2) = 0, so N = +4",\n      "marks": 4\n    },\n    {\n      "id": "2016_04_003",\n      "question_text": "The sum of first n natural numbers is:",\n      "subject": "Mathematics",\n      "difficulty": "Easy",\n      "options": [\n        {\n          "option": "A",\n          "value": "n(n+1)/2",\n          "is_correct": true\n        },\n        {\n          "option": "B",\n          "value": "n(n-1)/2",\n          "is_correct": false\n        },\n        {\n          "option": "C",\n          "value": "n²",\n          "is_correct": false\n        },\n        {\n          "option": "D",\n          "value": "n(n+2)/2",\n          "is_correct": false\n        }\n      ],\n      "correct_answer": "A",\n      "explanation": "The sum of first n natural numbers is 1+2+3+...+n = n(n+1)/2",\n      "marks": 4\n    },\n    {\n      "id": "2016_04_004",\n      "question_text": "A projectile is projected at an angle of 45° with velocity 20 m/s. The range is:",\n      "subject": "Physics",\n      "difficulty": "Medium",\n      "options": [\n        {\n          "option": "A",\n          "value": "20 m",\n          "is_correct": false\n        },\n        {\n          "option": "B",\n          "value": "40 m",\n          "is_correct": true\n        },\n        {\n          "option": "C",\n          "value": "60 m",\n          "is_correct": false\n        },\n        {\n          "option": "D",\n          "value": "80 m",\n          "is_correct": false\n        }\n      ],\n      "correct_answer": "B",\n      "explanation": "Range R = u²sin(2θ)/g = 400×sin(90°)/10 = 400/10 = 40 m (taking g = 10 m/s²)",\n      "marks": 4\n    },\n    {\n      "id": "2016_04_005",\n      "question_text": "Which of the following is not a greenhouse gas?",\n      "subject": "Chemistry",\n      "difficulty": "Medium",\n      "options": [\n        {\n          "option": "A",\n          "value": "CO₂",\n          "is_correct": false\n        },\n        {\n          "option": "B",\n          "value": "CH₄",\n          "is_correct": false\n        },\n        {\n          "option": "C",\n          "value": "N₂",\n          "is_correct": true\n        },\n        {\n          "option": "D",\n          "value": "N₂O",\n          "is_correct": false\n        }\n      ],\n      "correct_answer": "C",\n      "explanation": "N₂ (nitrogen gas) makes up about 78% of the atmosphere and is not a greenhouse gas. CO₂, CH₄, and N₂O are all greenhouse gases.",\n      "marks": 4\n    }\n  ]\n}