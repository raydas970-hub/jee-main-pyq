{\n  \"year\": 2017,\n  \"month\": \"January\",\n  \"session\": \"JEE Main 2017\",\n  \"questions\": [\n    {\n      \"id\": \"2017_01_001\",\n      \"question_text\": \"The escape velocity from Earth's surface is approximately:\",\n      \"subject\": \"Physics\",\n      \"difficulty\": \"Medium\",\n      \"options\": [\n        {\n          \"option\": \"A\",\n          \"value\": \"5.1 km/s\",\n          \"is_correct\": false\n        },\n        {\n          \"option\": \"B\",\n          \"value\": \"9.8 km/s\",\n          \"is_correct\": false\n        },\n        {\n          \"option\": \"C\",\n          \"value\": \"11.2 km/s\",\n          \"is_correct\": true\n        },\n        {\n          \"option\": \"D\",\n          \"value\": \"15.3 km/s\",\n          \"is_correct\": false\n        }\n      ],\n      \"correct_answer\": \"C\",\n      \"explanation\": \"The escape velocity from Earth is v_e = √(2GM/R) ≈ 11.2 km/s\",\n      \"marks\": 4\n    },\n    {\n      \"id\": \"2017_01_002\",\n      \"question_text\": \"The hybridization of carbon in CH₄ is:\",\n      \"subject\": \"Chemistry\",\n      \"difficulty\": \"Easy\",\n      \"options\": [\n        {\n          \"option\": \"A\",\n          \"value\": \"sp\",\n          \"is_correct\": false\n        },\n        {\n          \"option\": \"B\",\n          \"value\": \"sp²\",\n          \"is_correct\": false\n        },\n        {\n          \"option\": \"C\",\n          \"value\": \"sp³\",\n          \"is_correct\": true\n        },\n        {\n          \"option\": \"D\",\n          \"value\": \"sp³d\",\n          \"is_correct\": false\n        }\n      ],\n      \"correct_answer\": \"C\",\n      \"explanation\": \"In CH₄, carbon forms 4 single bonds with hydrogen atoms, resulting in sp³ hybridization\",\n      \"marks\": 4\n    },\n    {\n      \"id\": \"2017_01_003\",\n      \"question_text\": \"The derivative of x³ with respect to x is:\",\n      \"subject\": \"Mathematics\",\n      \"difficulty\": \"Easy\",\n      \"options\": [\n        {\n          \"option\": \"A\",\n          \"value\": \"3x\",\n          \"is_correct\": false\n        },\n        {\n          \"option\": \"B\",\n          \"value\": \"3x²\",\n          \"is_correct\": true\n        },\n        {\n          \"option\": \"C\",\n          \"value\": \"x²\",\n          \"is_correct\": false\n        },\n        {\n          \"option\": \"D\",\n          \"value\": \"3x³\",\n          \"is_correct\": false\n        }\n      ],\n      \"correct_answer\": \"B\",\n      \"explanation\": \"d/dx(x³) = 3x² by the power rule\",\n      \"marks\": 4\n    },\n    {\n      \"id\": \"2017_01_004\",\n      \"question_text\": \"The pH of a neutral solution at 25°C is:\",\n      \"subject\": \"Chemistry\",\n      \"difficulty\": \"Easy\",\n      \"options\": [\n        {\n          \"option\": \"A\",\n          \"value\": \"0\",\n          \"is_correct\": false\n        },\n        {\n          \"option\": \"B\",\n          \"value\": \"7\",\n          \"is_correct\": true\n        },\n        {\n          \"option\": \"C\",\n          \"value\": \"14\",\n          \"is_correct\": false\n        },\n        {\n          \"option\": \"D\",\n          \"value\": \"10\",\n          \"is_correct\": false\n        }\n      ],\n      \"correct_answer\": \"B\",\n      \"explanation\": \"At 25°C, a neutral solution has pH = 7, where [H⁺] = [OH⁻] = 10⁻⁷ M\",\n      \"marks\": 4\n    },\n    {\n      \"id\": \"2017_01_005\",\n      \"question_text\": \"The SI unit of force is:\",\n      \"subject\": \"Physics\",\n      \"difficulty\": \"Easy\",\n      \"options\": [\n        {\n          \"option\": \"A\",\n          \"value\": \"Dyne\",\n          \"is_correct\": false\n        },\n        {\n          \"option\": \"B\",\n          \"value\": \"Newton\",\n          \"is_correct\": true\n        },\n        {\n          \"option\": \"C\",\n          \"value\": \"Erg\",\n          \"is_correct\": false\n        },\n        {\n          \"option\": \"D\",\n          \"value\": \"Joule\",\n          \"is_correct\": false\n        }\n      ],\n      \"correct_answer\": \"B\",\n      \"explanation\": \"The SI unit of force is Newton (N), where 1 N = 1 kg·m/s²\",\n      \"marks\": 4\n    }\n  ]\n}